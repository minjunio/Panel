<!DOCTYPE html>
<html lang="en">
<head>
    <title>Login - studycloud</title>
    <%- include('partials/head') %>
</head>
<body class="flex items-center justify-center min-h-screen px-4">
    <div class="cloud w-[400px] h-[400px] top-10 left-10 opacity-70 animate-float"></div>
    <div class="glass-card p-6 md:p-8 w-full max-w-md relative z-10">
        <h2 class="text-2xl md:text-3xl font-black text-center mb-6 text-anime-textMain">Welcome Back ✨</h2>
        
        <% if (error) { %>
            <div class="bg-red-100 text-red-600 font-bold p-3 rounded-xl mb-4 text-center text-sm"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-black mb-1">Username</label>
                <input type="text" name="username" required class="w-full bg-white border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent">
            </div>
            <div>
                <label class="block text-sm font-black mb-1">Password</label>
                <input type="password" name="password" required class="w-full bg-white border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent">
            </div>
            <button type="submit" class="w-full bg-anime-accent text-white font-black py-3 rounded-xl hover:shadow-lg transition">Login</button>
        </form>
        <div class="text-center mt-4">
            <a href="/" class="text-sm font-bold text-anime-textDark hover:text-anime-accent">← Back to Store</a>
        </div>
    </div>
</body>
</html>
